# ── Secrets / per-developer config ───────────────────────────────
# These contain Firebase API keys and the OAuth client ID bound to
# YOUR Chrome Extension ID. Each contributor must create their own
# from the *.example.* templates committed to the repo.
manifest.json
firebase/firebase-config.js

# ── IDE / editor ────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.swp
.DS_Store

# ── Node / tooling (in case anyone adds it later) ───────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.firebase/
firebase-debug.log
firebase-debug.*.log

# ── Python (create_icons.py) ────────────────────────────────────
__pycache__/
*.pyc
.venv/
venv/

# ── Build / packaging ───────────────────────────────────────────
dist/
build/
*.zip
*.crx
*.pem

